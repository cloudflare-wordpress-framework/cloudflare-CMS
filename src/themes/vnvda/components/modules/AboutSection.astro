---
export interface Props {
	title?: string;
	content?: string;
	linkText?: string;
	linkUrl?: string;
}

const {
	title = 'Về chúng tôi',
	content = 'Hội Bệnh Mạch Máu Việt Nam (VNVDA) là tổ chức xã hội - nghề nghiệp của các cá nhân, tổ chức hoạt động trong lĩnh vực chuyên ngành bệnh mạch máu và các chuyên ngành có liên quan tại Việt Nam.',
	linkText = 'Xem thêm',
	linkUrl = '/gioi-thieu/lich-su-hinh-thanh/'
} = Astro.props;
---

<section class="about-section">
	<div class="container">
		<div class="about-content">
			<h2>{title}</h2>
			<p>{content}</p>
			<a href={linkUrl} class="btn-readmore">{linkText}</a>
		</div>
	</div>
</section>

<style>
	h2 {
		color: var(--vnvda-blue);
		text-align: center;
		margin-bottom: 30px;
		font-size: 2rem;
		text-transform: uppercase;
	}
	.about-section {
		background-color: #f9f9f9;
        padding: 40px 0;
	}
	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 15px;
	}
	.about-content {
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
	}
	.about-content p {
		font-size: 1.1rem;
		line-height: 1.6;
		margin-bottom: 20px;
	}
	.btn-readmore {
		display: inline-block;
		background-color: var(--vnvda-blue);
		color: white;
		padding: 10px 25px;
		text-decoration: none;
		border-radius: 4px;
		font-weight: 600;
		transition: background-color 0.3s;
	}
	.btn-readmore:hover {
		background-color: #003d82;
	}
    @media (max-width: 768px) {
		h2 {
			font-size: 1.5rem;
		}
		.about-section {
			padding: 30px 0;
		}
	}
</style>
