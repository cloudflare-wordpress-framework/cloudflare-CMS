---
export const prerender = true;
import PublicLayout from '../../layouts/PublicLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';

export async function getStaticPaths() {
    const mdPostsGlob = import.meta.glob('../posts/*.md', { eager: true });
    const mdPosts = Object.values(mdPostsGlob);

    // Extract unique categories from posts
    const categories = new Set();
    mdPosts.forEach((p: any) => {
        if (p.frontmatter.category) {
            categories.add(p.frontmatter.category);
        }
    });

    return Array.from(categories).map(slug => ({
        params: { slug },
        props: { slug }
    }));
}

const { slug } = Astro.props;

let category = { name: slug?.replace(/-/g, ' ').toUpperCase(), slug };

// Fetch posts from markdown (simplistic category matching based on frontmatter)
const mdPostsGlob = import.meta.glob('../posts/*.md', { eager: true });
const mdPosts = Object.values(mdPostsGlob);
const parsedMdPosts = mdPosts
    .filter((p: any) => p.frontmatter.category === slug) // simplistic filter
    .map((p: any) => ({
        title: p.frontmatter.title,
        slug: p.frontmatter.slug || p.file.split('/').pop()?.replace('.md', ''),
        excerpt: p.frontmatter.excerpt,
        published_at: p.frontmatter.published_at,
        image: p.frontmatter.image,
    }));

// Combine and sort
const allPosts = [...parsedMdPosts].sort((a, b) => {
    return new Date(b.published_at).getTime() - new Date(a.published_at).getTime();
});

function formatDate(dateString: string) {
    if (!dateString) return '';
    const date = new Date(dateString);
    return date.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
}
---

<PublicLayout title={`Chuyên mục: ${category.name} | Hội Bệnh Mạch Máu Việt Nam`}>
	<Header />

	<main class="category-page">
		<div class="container">
			<h1>Chuyên mục: {category.name}</h1>

            {allPosts.length > 0 ? (
                <div class="news-grid">
                    {allPosts.map(post => (
                        <article class="news-card">
                            {post.image ? (
                                <div class="news-img" style={`background-image: url(${post.image}); height: 200px;`}></div>
                            ) : (
                                <div class="news-img" style="background-color: #ddd; height: 200px;"></div>
                            )}
                            <div class="news-info">
                                <h3><a href={`/posts/${post.slug}`}>{post.title}</a></h3>
                                <p class="date">{formatDate(post.published_at)}</p>
                                <p>{post.excerpt}</p>
                            </div>
                        </article>
                    ))}
                </div>
            ) : (
                <p>Chưa có bài viết nào trong chuyên mục này.</p>
            )}
		</div>
	</main>

	<Footer />
</PublicLayout>

<style>
    main {
        flex: 1;
    }
    .category-page {
        padding: 40px 0;
    }
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 15px;
    }
    h1 {
        color: var(--vnvda-blue);
        margin-bottom: 30px;
        font-size: 2rem;
        border-bottom: 2px solid var(--vnvda-blue);
        padding-bottom: 10px;
        display: inline-block;
    }
    .news-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 30px;
	}
	.news-card {
		background: white;
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 4px 15px rgba(0,0,0,0.1);
		transition: transform 0.3s;
	}
	.news-card:hover {
		transform: translateY(-5px);
	}
	.news-img {
		width: 100%;
		background-size: cover;
		background-position: center;
	}
	.news-info {
		padding: 20px;
	}
	.news-info h3 {
		margin: 0 0 10px;
		font-size: 1.2rem;
	}
	.news-info h3 a {
		color: var(--vnvda-text);
		text-decoration: none;
		transition: color 0.3s;
	}
	.news-info h3 a:hover {
		color: var(--vnvda-blue);
	}
	.date {
		color: #777;
		font-size: 0.9rem;
		margin-bottom: 10px;
	}
	.news-info p {
		margin: 0;
		color: #555;
		line-height: 1.5;
	}
</style>
