---
import Layout from '../themes/vnvda/layouts/Layout.astro';
import Header from '../themes/vnvda/components/Header.astro';
import Footer from '../themes/vnvda/components/Footer.astro';
import Slider from '../themes/vnvda/components/modules/Slider.astro';
import AboutSection from '../themes/vnvda/components/modules/AboutSection.astro';
import NewsSection from '../themes/vnvda/components/modules/NewsSection.astro';

import { env } from "cloudflare:workers";

// Fetch dynamic theme settings from D1
let themeSettings: Record<string, string> = {};
let dbPosts = [];
try {
    // @ts-ignore
    const db = env.DB;
    if (db) {
        const { results: settingsResults } = await db.prepare('SELECT * FROM theme_settings').all();
        settingsResults.forEach((row: any) => {
            themeSettings[row.setting_key] = row.setting_value;
        });

        const { results: postResults } = await db.prepare('SELECT * FROM posts WHERE status = ? ORDER BY published_at DESC LIMIT 6').bind('published').all();
        dbPosts = postResults;
    }
} catch (e) {
    console.error('Error fetching data from D1:', e);
}

// Fetch posts from markdown
const mdPostsGlob = import.meta.glob('./posts/*.md', { eager: true });
const mdPosts = Object.values(mdPostsGlob);
const parsedMdPosts = mdPosts.map(p => ({
    title: p.frontmatter.title,
    slug: p.frontmatter.slug || p.file.split('/').pop()?.replace('.md', ''),
    excerpt: p.frontmatter.excerpt,
    published_at: p.frontmatter.published_at,
    image: p.frontmatter.image,
    content: p.compiledContent()
}));

// Combine and sort
const allPosts = [...dbPosts, ...parsedMdPosts].sort((a, b) => {
    return new Date(b.published_at).getTime() - new Date(a.published_at).getTime();
}).slice(0, 6);

// Default slider data if not set in CMS
const defaultSlideData = [
	{
		image: 'https://vnvda.com/wp-content/uploads/2024/05/banner-vnvda.jpg',
		title: 'Hội Bệnh Mạch Máu Việt Nam',
		description: 'Chào mừng đến với trang thông tin chính thức của Hội Bệnh Mạch Máu Việt Nam'
	},
	{
		image: 'https://vnvda.com/wp-content/uploads/2024/05/hinh-anh-hoi-nghi.jpg',
		title: 'Hội nghị khoa học',
		description: 'Cập nhật kiến thức và tiến bộ mới nhất trong lĩnh vực bệnh mạch máu'
	}
];

let slideData = defaultSlideData;
if (themeSettings['home_slider']) {
    try {
        slideData = JSON.parse(themeSettings['home_slider']);
    } catch(e) {}
}

const aboutTitle = themeSettings['home_about_title'];
const aboutContent = themeSettings['home_about_content'];
const aboutLinkText = themeSettings['home_about_link_text'];
const aboutLinkUrl = themeSettings['home_about_link_url'];

const newsTitle = themeSettings['home_news_title'];
---

<Layout title="Trang chủ | Hội Bệnh Mạch Máu Việt Nam">
	<Header />

	<main>
		<section class="hero-section">
			<Slider slides={slideData} autoplay={true} interval={6000} />
		</section>

		<AboutSection
            title={aboutTitle}
            content={aboutContent}
            linkText={aboutLinkText}
            linkUrl={aboutLinkUrl}
        />

		<NewsSection
            title={newsTitle}
            posts={allPosts}
        />
	</main>

	<Footer />
</Layout>

<style>
	main {
		flex: 1;
	}

	.hero-section {
		padding: 20px 0 40px;
	}
</style>
