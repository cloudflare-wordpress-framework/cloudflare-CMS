---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="vi">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Hội Bệnh Mạch Máu Việt Nam (vnvda.com) - Trang chính thức của Hội bệnh mạch máu Việt Nam" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="https://vnvda.com/wp-content/uploads/2024/05/vnvda-favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	:root {
		--vnvda-blue: #0056b3;
        --vnvda-light-blue: #e7f1ff;
        --vnvda-text: #333333;
        --vnvda-bg: #ffffff;
	}
	html {
		font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
		background: var(--vnvda-bg);
        color: var(--vnvda-text);
        scroll-behavior: smooth;
	}
    body {
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }
    * {
        box-sizing: border-box;
    }

    img {
        max-width: 100%;
        height: auto;
    }
</style>
