---
export interface Props {
    title?: string;
    categorySlug: string;
    limit?: number;
}

const { title = 'Bài viết liên quan', categorySlug, limit = 6 } = Astro.props;

// Tạo unique id cho container để script có thể query chính xác khi có nhiều module trên 1 trang
const containerId = `category-ajax-${Math.random().toString(36).substring(2, 9)}`;
---

<section class="news-section">
	<div class="container">
		{title && <h2>{title}</h2>}

        <!-- Khung chứa HTML trống, sẽ được Vue/JS đắp data vào -->
        <div id={containerId} class="news-grid" data-category={categorySlug} data-limit={limit}>
            <!-- Hiệu ứng loading skeleton -->
            <div class="loading-placeholder">Đang tải bài viết...</div>
        </div>
	</div>
</section>

<script>
    // Định nghĩa hàm để load và render
    async function loadCategoryPosts(container: HTMLElement) {
        const categorySlug = container.dataset.category;
        const limit = parseInt(container.dataset.limit || '6', 10);

        if (!categorySlug) return;

        try {
            // Fetch file JSON tĩnh đã được build bởi Astro
            const response = await fetch(`/api/category/${categorySlug}.json`);
            if (!response.ok) {
                throw new Error('Network response was not ok');
            }
            const posts = await response.json();

            // Xóa loading placeholder
            container.innerHTML = '';

            if (posts.length === 0) {
                container.innerHTML = '<p class="no-posts">Chưa có bài viết nào.</p>';
                return;
            }

            // Lấy limit số bài
            const postsToShow = posts.slice(0, limit);

            // Hàm định dạng ngày
            const formatDate = (dateStr: string) => {
                if(!dateStr) return '';
                const d = new Date(dateStr);
                return d.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
            }

            // Render HTML trực tiếp qua JS (Vanilla JS tương tự cơ chế Vue client)
            postsToShow.forEach((post: any) => {
                const article = document.createElement('article');
                article.className = 'news-card';

                const imgDiv = document.createElement('div');
                imgDiv.className = 'news-img';
                if (post.image) {
                    imgDiv.style.backgroundImage = `url(${post.image})`;
                } else {
                    imgDiv.style.backgroundColor = '#ddd';
                }
                imgDiv.style.height = '200px';

                const infoDiv = document.createElement('div');
                infoDiv.className = 'news-info';

                const titleH3 = document.createElement('h3');
                const titleLink = document.createElement('a');
                titleLink.href = `/posts/${post.slug}`;
                titleLink.textContent = post.title;
                titleH3.appendChild(titleLink);

                const dateP = document.createElement('p');
                dateP.className = 'date';
                dateP.textContent = formatDate(post.published_at);

                const excerptP = document.createElement('p');
                excerptP.textContent = post.excerpt || '';

                infoDiv.appendChild(titleH3);
                infoDiv.appendChild(dateP);
                infoDiv.appendChild(excerptP);

                article.appendChild(imgDiv);
                article.appendChild(infoDiv);

                container.appendChild(article);
            });

        } catch (error) {
            console.error('Error fetching category posts:', error);
            container.innerHTML = '<p class="error-msg">Không thể tải bài viết lúc này.</p>';
        }
    }

    // Chạy script ngay khi DOM loaded
    document.addEventListener('DOMContentLoaded', () => {
        const containers = document.querySelectorAll('.news-grid[data-category]');
        containers.forEach(container => {
            loadCategoryPosts(container as HTMLElement);
        });
    });
</script>

<style>
	h2 {
		color: var(--vnvda-blue);
		text-align: center;
		margin-bottom: 30px;
		font-size: 2rem;
		text-transform: uppercase;
	}
	.news-section {
        padding: 40px 0;
	}
	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 15px;
	}
	.news-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 30px;
	}
    /* CSS cho dynamic content render bởi JS */
	:global(.news-card) {
		background: white;
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 4px 15px rgba(0,0,0,0.1);
		transition: transform 0.3s;
	}
	:global(.news-card:hover) {
		transform: translateY(-5px);
	}
	:global(.news-img) {
		width: 100%;
		background-size: cover;
		background-position: center;
	}
	:global(.news-info) {
		padding: 20px;
	}
	:global(.news-info h3) {
		margin: 0 0 10px;
		font-size: 1.2rem;
	}
	:global(.news-info h3 a) {
		color: var(--vnvda-text);
		text-decoration: none;
		transition: color 0.3s;
	}
	:global(.news-info h3 a:hover) {
		color: var(--vnvda-blue);
	}
	:global(.news-info p.date) {
		color: #777;
		font-size: 0.9rem;
		margin-bottom: 10px;
	}
	:global(.news-info p:not(.date)) {
		margin: 0;
		color: #555;
		line-height: 1.5;
	}
    .loading-placeholder {
        grid-column: 1 / -1;
        text-align: center;
        padding: 40px;
        color: #777;
    }
    .no-posts, .error-msg {
        grid-column: 1 / -1;
        text-align: center;
        padding: 20px;
        color: #777;
    }
    @media (max-width: 768px) {
		h2 {
			font-size: 1.5rem;
		}
		.news-section {
			padding: 30px 0;
		}
	}
</style>
