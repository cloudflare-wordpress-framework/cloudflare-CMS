# Cloudflare settings
PROJECT_NAME=afraid-atmosphere
COMPATIBILITY_DATE=2026-06-30

# D1 Database settings (CMS)
D1_BINDING=DB
D1_DATABASE_NAME=cms-db
D1_DATABASE_ID=local-setup-only-replace-on-production
D1_REMOTE=false

# D1 Database settings (Users)
