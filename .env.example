USER_DB_DATABASE_ID=local-setup-only-replace-on-production
USER_DB_REMOTE=false

# Firebase settings (Local)
FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your_auth_domain
