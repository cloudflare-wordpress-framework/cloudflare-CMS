{
  "name": "afraid-atmosphere",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "db:create": "wrangler d1 create cms-db",
    "db:init:local": "wrangler d1 execute cms-db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute cms-db --remote --file=./schema.sql",
    "deploy": "npm run build && wrangler pages deploy ./dist",
    "setup:local": "npm install && npm run db:init:local"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.1",
    "astro": "^7.0.3",
    "wrangler": "^4.105.0"
  }
}